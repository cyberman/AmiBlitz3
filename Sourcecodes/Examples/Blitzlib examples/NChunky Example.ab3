; /XTRA
; *********************************************************
;                  New Chunky Library
;    Coded by AlphaSOUND - (c) 1998 Fantaisie software
;    Frédéric Laboureu
; *********************************************************

; *********************************************************
;                     Example 1
; Allocate a ChunkyBuffer and display it on a planar Screen
; *********************************************************

WBStartup

NInitChunky 0

; *********************************************************
;                     Starting Program...
; *********************************************************
NChunkyBuffer 0,320,200  ; Should be tested

*BitmapPtr.l = AllocMem_((320*200)+10000, 2|65536)
CludgeBitMap 0,320,200,8,*BitmapPtr+8
Screen 0,0,0,320,200,8,0,"New Library Chunky Test V1.50",0,0,0
Use BitMap 0: BitMapOutput 0

a = 0
Repeat
  NChunkyBlit 8, 8, ?ChunkyShape1, 20+a,20

  NChunkyBlock 8, 8, ?ChunkyShape1, 100,20+a

  NChunkyBlock 8, 8, ?ChunkyShape2, 150,180-a

  NChunkyBlock 8, 8, ?ChunkyShape2, 20+a,50+a

  NChunkyBlock 8, 8, ?ChunkyShape2, 80, 30+a

  NChunkyPlot Rnd(319),Rnd(199),Rnd(255)

  NChunkyBoxf 10+Rnd(10),10+Rnd(10),20+Rnd(10),20+Rnd(10),Rnd(255)

  ;-- do the chunky to planar conversion

  Select chunkymethod
  Case 0    ; highly optimized routine, needs 68040+ and is limited to resolution 320x200
    c2p040_320_200 NChunkyID, *BitmapPtr+4

  Case 1    ; standard os function that came with OS3.1.4
    *scr.Screen = Peek.l(Addr Screen(0))
    WriteChunkyPixels_ *scr\RastPort,0,0,319,199,NChunkyID,320

  Case 2    ; native used version of WriteChunkyPixels
    NChunkyToBitmapV40(0)

  Case 3    ; standard os function WritePixelArray8 that came with OS2.0, but needs AllocBitmap of OS3.0
    written.l = NChunkyToBitmapV39(0)
    Locate 0,0 : Print written
  End Select
  a + 1
  VWait

Until a = 100 OR Joyb(0) = 1

MouseWait

End

ChunkyShape1:
Dc.b 0,0,0,1,1,0,0,0
Dc.b 0,0,0,1,1,0,0,0
Dc.b 0,0,0,1,1,0,0,0
Dc.b 1,1,1,1,1,1,1,1
Dc.b 1,1,1,1,1,1,1,1
Dc.b 0,0,0,1,1,0,0,0
Dc.b 0,0,0,1,1,0,0,0
Dc.b 0,0,0,1,1,0,0,0


ChunkyShape2:
Dc.b 5,0,0,1,1,0,0,5
Dc.b 0,0,0,1,1,0,0,0
Dc.b 0,0,0,1,1,0,0,0
Dc.b 1,1,1,6,6,1,1,1
Dc.b 1,1,1,6,6,1,1,1
Dc.b 0,0,0,1,1,0,0,0
Dc.b 0,0,0,1,1,0,0,0
Dc.b 5,0,0,1,1,0,0,5

