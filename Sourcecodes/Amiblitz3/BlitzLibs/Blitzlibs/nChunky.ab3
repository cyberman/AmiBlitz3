!libheader{#nchunkylib,0,0,finit,0}

!acommand{#long}
!args{#long,#word,#word}
!libs
!subs{do_nchunkybuffer,0,0}
!name{"NChunkyBuffer","(#Buffer, Width, Height) - Allocate a chunky buffer"}

!astatement
!args{#word,#word,#long,#word,#word}
!libs
!subs{do_nchunkyblit,0,0}
!name{"NChunkyBlit","ShapeWidth, ShapeHeight, ShapeAddress, X, Y"}

!astatement
!args{#word,#word,#long,#word,#word}
!libs
!subs{do_nchunkyblock,0,0}
!name{"NChunkyBlock","ShapeWidth, ShapeHeight, ShapeAddress, X, Y"}

!astatement
!args{#byte}
!libs
!subs{do_nchunkycls,0,0}
!name{"NChunkyCls","Colour"}

!astatement
!args{#word,#word,#byte}
!libs
!subs{do_nchunkyplot,0,0}
!name{"NChunkyPlot","X, Y, Colour"}

!astatement
!args{#long}
!libs
!subs{do_nusechunkybuffer,0,0}
!name{"NUseChunkyBuffer","#Buffer"}

